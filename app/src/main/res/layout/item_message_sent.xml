<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/message_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        android:background="@drawable/bg_message_sent"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Вариант 1: Одна строка, время справа -->
        <LinearLayout
            android:id="@+id/layout_single_line"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Сообщение"
                android:textColor="#000000"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.7"
                android:text="12:00"
                android:textColor="#666666"
                android:textSize="11sp"
                android:translationY="5dp"
                android:paddingBottom="8dp" />

            <!-- 👇 Иконка статуса для односточного варианта -->
            <ImageView
                android:id="@+id/iv_status_single"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_check_sent"
                android:visibility="visible"
                android:translationY="6dp"
                />

        </LinearLayout>

        <!-- Вариант 2: Несколько строк, время на последней строке (если влезает) -->
        <RelativeLayout
            android:id="@+id/layout_multi_line"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_message_multi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сообщение"
                android:textColor="#000000"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_time_multi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignEnd="@id/tv_message_multi"
                android:layout_alignBottom="@id/tv_message_multi"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="-9dp"
                android:alpha="0.7"
                android:text="12:00"
                android:textColor="#666666"
                android:textSize="11sp"
                android:includeFontPadding="true"
                android:paddingBottom="6dp" />

            <!-- 👇 Иконка статуса для мультистрочного варианта -->
            <ImageView
                android:id="@+id/iv_status_multi"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_alignEnd="@id/tv_time_multi"
                android:layout_alignBottom="@id/tv_time_multi"
                android:layout_marginEnd="-16dp"
                android:layout_marginBottom="5dp"

                android:src="@drawable/ic_check_sent"
                android:visibility="visible" />

        </RelativeLayout>

        <!-- Вариант 3: Много строк/нет места, время отдельно снизу -->
        <LinearLayout
            android:id="@+id/layout_bottom_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_message_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="4dp"
                android:text="Сообщение"
                android:textColor="#000000"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_time_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:text="12:00"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:translationY="5dp"
                    android:paddingBottom="8dp"/>

                <!-- 👇 Иконка статуса для варианта с временем снизу -->
                <ImageView
                    android:id="@+id/iv_status_bottom"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_check_sent"
                    android:visibility="visible"
                    android:translationY="2dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>